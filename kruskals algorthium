from typing import List
class Disjoint:
    def __init__(self,V):
        self.rank=[0]*V
        self.parent=[i for i in range(V)]
    def findParent(self,node):
        if node==self.parent[node]:
            return node
        self.parent[node]=self.findParent(self.parent[node])
        return self.parent[node]
    def unionbyrank(self,u,v):
        ultimateparentofU=self.findParent(u)
        ultimateparentofV=self.findParent(v)
        if ultimateparentofU==ultimateparentofV:
                return
        if self.rank[ultimateparentofU]<self.rank[ultimateparentofV]:
            self.parent[ultimateparentofU]=ultimateparentofV
        elif self.rank[ultimateparentofU]>self.rank[ultimateparentofV]:
            self.parent[ultimateparentofV]=ultimateparentofU
        elif self.rank[ultimateparentofU]==self.rank[ultimateparentofV]:
            self.parent[ultimateparentofU]=ultimateparentofV
            self.rank[ultimateparentofU]+=1
    

       
class Solution:
    def kruskalsMST(self, V: int, edges: List[List[int]]) -> int:
            ds=Disjoint(V)
            sum=0
            edges.sort(key=lambda x:x[2])
            for u,v,w in edges:
                if(ds.findParent(u)!=ds.findParent(v)):
                    sum+=w
                    ds.unionbyrank(u,v)
            return sum
                
            
                
                
            
                
            
        
            
            
